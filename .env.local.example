# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DeepSeek API（OpenAI 兼容接口）
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 阿里云 DashScope（AI 顾问图片分析，可选）
DASHSCOPE_API_KEY=
DASHSCOPE_VL_MODEL=qwen-vl-max

# 站点
NEXT_PUBLIC_SITE_URL=https://www.yovigo.cn

# 管理员邮箱（服务端 ADMIN_EMAIL 与客户端 NEXT_PUBLIC_ADMIN_EMAIL 保持一致）
ADMIN_EMAIL=your_email@qq.com
NEXT_PUBLIC_ADMIN_EMAIL=your_email@qq.com

# 微信小程序（可选，/api/wechat/login）
# WECHAT_APP_ID=wx_your_app_id
# WECHAT_APP_SECRET=your_app_secret
# WECHAT_LOGIN_SECRET=random_secret_for_wechat_password_hmac

# 微信支付（可选，/api/payment/wechat/notify）
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_NOTIFY_DEBUG=true
